#!/bin/bash

is_container_running() {
  docker inspect "$1" 2>/dev/null | grep -q '"Status": "running"'
}

case "${1:-}" in
  start|stop)
    exit 0
    ;;
  status)
    if is_container_running searxng-fpk && is_container_running searxng-admin-fpk; then
      exit 0
    fi
    exit 3
    ;;
  *)
    exit 1
    ;;
esac
